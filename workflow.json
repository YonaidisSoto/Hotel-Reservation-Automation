{
  "name": "Hotel Reservation Automation",
  "nodes": [
    {
      "id": "d1e1a1c0-1a2b-4c3d-8e4f-1a2b3c4d7e01",
      "name": "Run Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [-1600, 800],
      "parameters": {
        "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] }
      }
    },
    {
      "id": "d1e1a1c0-1a2b-4c3d-8e4f-1a2b3c4d7e02",
      "name": "Read Reservations",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [-1344, 800],
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "value": "YOUR_GOOGLE_SHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Reservations", "mode": "name" },
        "options": {}
      }
    },
    {
      "id": "d1e1a1c0-1a2b-4c3d-8e4f-1a2b3c4d7e03",
      "name": "Pending Reservations",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.3,
      "position": [-1088, 560],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "cond_pending", "leftValue": "={{ $json.Status }}", "rightValue": "Pending", "operator": { "type": "string", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "d1e1a1c0-1a2b-4c3d-8e4f-1a2b3c4d7e04",
      "name": "Sync with Calendar",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [-832, 560],
      "parameters": {
        "resource": "event",
        "operation": "update",
        "calendar": { "__rl": true, "value": "your-calendar-email@gmail.com", "mode": "list", "cachedResultName": "your-calendar-email@gmail.com" },
        "eventId": "={{ $json.Google_Event_ID }}",
        "updateFields": {
          "description": "=Reservation CONFIRMED - {{ $json.Guest_Name }} - {{ $json.Room_Type }}"
        }
      }
    },
    {
