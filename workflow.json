      "type": "n8n-nodes-evolution-api.evolutionApi",
      "typeVersion": 1,
      "position": [-576, 560],
      "parameters": {
        "resource": "messages-api",
        "instanceName": "Hotel",
        "remoteJid": "={{ $json.Guest_Phone }}@s.whatsapp.net",
        "messageText": "=Hi {{ $json.Guest_Name }}! 🏨 Your reservation at *[HOTEL_NAME]* is confirmed:\n\n📅 Check-in: {{ $json.Check_In }}\n📅 Check-out: {{ $json.Check_Out }}\n🛏️ Room: {{ $json.Room_Type }}\n\nWe look forward to welcoming you! If you need anything, just reply to this WhatsApp.",
